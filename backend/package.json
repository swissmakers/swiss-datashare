{
  "name": "swiss-datashare-backend",
  "version": "1.13.0",
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "prod": "PRISMA_HIDE_UPDATE_MESSAGE=1 prisma migrate deploy && PRISMA_HIDE_UPDATE_MESSAGE=1 prisma db seed && node dist/src/main",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --end-of-line=auto --write 'src/**/*.ts'",
    "test:system": "PRISMA_HIDE_UPDATE_MESSAGE=1 prisma migrate reset -f && nest start & wait-on http://localhost:8080/api/configs && npx newman run ./test/newman-system-tests.json"
  },
  "prisma": {
    "seed": "ts-node --project prisma/seed/tsconfig.seed.json --transpile-only prisma/seed/config.seed.ts"
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/jmespath": "^0.15.2",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "body-parser": "^2.2.2",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "clamscan": "^2.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "content-disposition": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "jmespath": "^0.16.0",
    "ldapts": "^8.1.7",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "nanoid": "^5.1.9",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "qrcode-svg": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "ts-node": "^10.9.2",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/archiver": "^7.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode-svg": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "glob": "^11.0.0",
    "@humanwhocodes/config-array": "npm:@eslint/config-array@^0.18.0",
    "@humanwhocodes/object-schema": "npm:@eslint/object-schema@^2.1.0"
  }
}
